# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI Base URL (for proxy or alternative endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Server Configuration (Optional)
HOST=0.0.0.0
PORT=8000

# Whisper Model Configuration (Optional)
# Options: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base

# Local upload size limit in MB (optional; Docker Compose passes this through)
UPLOAD_MAX_MB=200

# AI Model Configuration (Optional)
# FAST_MODEL is used for formatting/typo-correction tasks (default: gpt-3.5-turbo)
# SMART_MODEL is used for summarization/translation tasks (default: gpt-4o)
# FAST_MODEL=gpt-3.5-turbo
# SMART_MODEL=gpt-4o
